[
  {
    "id": "factory_agent_01_director",
    "name": "Factory Director",
    "phase": "orchestration",
    "mode": "python_first_llm_sparse",
    "mission": "Owns the whole run, keeps gates honest and prevents scope drift."
  },
  {
    "id": "factory_agent_02_catalog",
    "name": "Catalog Normalizer",
    "phase": "discovery",
    "mode": "python_only",
    "mission": "Normalizes copilot IDs, connector names, env names and outputs.",
    "outputs": [
      "normalized_copilot_catalog",
      "normalized_route_payload",
      "runtime_trace_index"
    ],
    "normalization_contract": {
      "version": "catalog-normalization-1.0",
      "source": "data/copilots.json",
      "generated_index": "generated/copilot-index.json",
      "router": "tools/semantic_router.py",
      "canonical_fields": {
        "copilot_id": "lower_snake_case",
        "connector_names": "lower_snake_case",
        "env_names": "upper_snake_case",
        "outputs": "lower_snake_case"
      },
      "runtime_equivalence": {
        "sourceOfTruth": "dist/copilots/<copilot_id>/shared/spec.json",
        "runtimes": [
          "codex",
          "claude",
          "github-copilot",
          "langchain"
        ],
        "maxUnexplainedDrift": 0
      }
    }
  },
  {
    "id": "factory_agent_03_semantics",
    "name": "Semantic Router",
    "phase": "discovery",
    "mode": "python_only",
    "mission": "Uses deterministic Python scoring before any LLM assist.",
    "outputs": [
      "deterministic_route_scores",
      "route_confidence_payload",
      "llm_escalation_guard"
    ],
    "deterministic_scoring_contract": {
      "version": "semantic-routing-1.0",
      "router": "tools/semantic_router.py",
      "catalog": "data/copilots.json",
      "index": "generated/copilot-index.json",
      "score_inputs": [
        "id",
        "family",
        "function",
        "connectors",
        "env_keys",
        "stacks",
        "sdlc_phases",
        "outputs"
      ],
      "execution_order": [
        "validate_request",
        "load_catalog",
        "load_index",
        "score_catalog",
        "rank_routes",
        "attach_runtime_trace",
        "return_route_payload"
      ],
      "cheap_path_threshold": 3.0,
      "max_route_limit": 10,
      "llm_assist": {
        "before_scoring": false,
        "default": "disabled",
        "escalation": "allowed_after_no_cheap_path_only",
        "trace_field": "routing_evidence.llm_assist_used"
      },
      "runtime_equivalence": {
        "runtimes": [
          "codex",
          "claude",
          "github-copilot",
          "langchain"
        ],
        "same_scoring_policy": true,
        "runtime_trace_required": true
      },
      "score_model": "weighted_exact_and_token_overlap"
    }
  },
  {
    "id": "factory_agent_04_discovery",
    "name": "Discovery Auditor",
    "phase": "discovery",
    "mode": "python_first_llm_sparse",
    "mission": "Audits AS-IS coverage and repo inventory contracts.",
    "outputs": [
      "as_is_coverage_audit",
      "repo_inventory_contract",
      "coverage_gap_register"
    ],
    "as_is_inventory_contract": {
      "version": "as-is-inventory-audit-1.0",
      "source_catalog": "data/copilots.json",
      "generated_index": "generated/copilot-index.json",
      "router": "tools/semantic_router.py",
      "target_copilot": "as_is_discovery",
      "required_outputs": [
        "as_is_report",
        "inventory_json"
      ],
      "coverage_items": [
        "source_systems",
        "repository_topology",
        "interfaces",
        "data_flows",
        "business_rules",
        "dependencies",
        "owners",
        "risks",
        "validation_signals"
      ],
      "inventory_fields": [
        "path",
        "artifact_type",
        "owner",
        "sdlc_phase",
        "runtime_scope",
        "evidence_ref",
        "validation_status"
      ],
      "execution_order": [
        "load_catalog",
        "load_index",
        "collect_runtime_trace",
        "audit_as_is_outputs",
        "audit_inventory_contract",
        "emit_gap_register",
        "return_discovery_audit"
      ],
      "evidence_field": "discovery_audit",
      "gap_register_required": true,
      "validation_commands": [
        "python tools/validate_copilot_factory.py",
        "python tools/semantic_router.py as_is inventory coverage",
        "python tools/semantic_router.py python ci routing"
      ],
      "runtime_equivalence": {
        "runtimes": [
          "codex",
          "claude",
          "github-copilot",
          "langchain"
        ],
        "source_of_truth": "dist/copilots/as_is_discovery/shared/spec.json",
        "max_unexplained_drift": 0
      }
    }
  },
