{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Copiloto SonarQube Remediacion Output Contract",
  "type": "object",
  "required": [
    "copilot_id",
    "decision",
    "phase",
    "expected_outputs",
    "evidence",
    "findings",
    "actions",
    "validation",
    "risks",
    "runtime_trace",
    "cost_budget"
  ],
  "properties": {
    "copilot_id": {
      "const": "sonarqube_remediation"
    },
    "decision": {
      "type": "string"
    },
    "phase": {
      "enum": [
        "test",
        "security",
        "release"
      ]
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "enum": [
          "sonar_report",
          "remediation_backlog"
        ]
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "ref",
          "summary"
        ]
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "evidence_ref",
          "reproduction_path",
          "verification_command"
        ],
        "properties": {
          "severity": {
            "enum": [
              "INFO",
              "MINOR",
              "MAJOR",
              "CRITICAL",
              "BLOCKER"
            ]
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "owner",
          "action",
          "scope",
          "evidence_ref",
          "validation_method"
        ]
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "runtime_trace": {
      "type": "object",
      "required": [
        "runtime",
        "source_of_truth",
        "schema_ref",
        "max_unexplained_drift",
        "prompt_bodies_stored"
      ],
      "properties": {
        "runtime": {
          "enum": [
            "codex",
            "claude",
            "github-copilot",
            "langchain"
          ]
        },
        "max_unexplained_drift": {
          "const": 0
        },
        "prompt_bodies_stored": {
          "const": false
        }
      }
    },
    "cost_budget": {
      "type": "object",
      "required": [
        "routing_mode",
        "deterministic_first",
        "prompt_bodies_stored"
      ],
      "properties": {
        "routing_mode": {
          "const": "python_first_llm_sparse"
        },
        "deterministic_first": {
          "const": true
        },
        "max_evidence_refs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "prompt_bodies_stored": {
          "const": false
        }
      }
    },
    "handoff": {
      "type": "object"
    }
  }
}
