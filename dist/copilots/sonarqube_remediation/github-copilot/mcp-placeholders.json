{
  "policyVersion": "github-copilot-profile-mcp-placeholders-1.0",
  "ownerAgent": "factory_agent_16_github",
  "mission": "Builds GitHub Copilot profile docs and MCP placeholders.",
  "copilotId": "sonarqube_remediation",
  "runtime": "github-copilot",
  "sourcePolicy": "config/mcp-connectors.example.json",
  "defaultEnabled": false,
  "placeholderOnly": true,
  "credentialsRequired": false,
  "credentialValuesStored": false,
  "customerDataAllowed": false,
  "billingDataAllowed": false,
  "connectors": {
    "github_mcp": {
      "connector": "github_mcp",
      "enabled": false,
      "env": "GITHUB_TOKEN",
      "envReference": "${GITHUB_TOKEN}",
      "credentialValue": "",
      "credentialValuesStored": false,
      "requiresOperatorActivation": true,
      "operatorApprovalRequiredForWrites": true,
      "localOnlyConfig": true,
      "allowedRuntimes": [
        "codex",
        "claude",
        "github-copilot",
        "langchain"
      ],
      "policyRef": "config/mcp-connectors.example.json"
    },
    "sonarqube_mcp": {
      "connector": "sonarqube_mcp",
      "enabled": false,
      "env": "SONARQUBE_TOKEN",
      "envReference": "${SONARQUBE_TOKEN}",
      "credentialValue": "",
      "credentialValuesStored": false,
      "requiresOperatorActivation": true,
      "operatorApprovalRequiredForWrites": true,
      "localOnlyConfig": true,
      "allowedRuntimes": [
        "codex",
        "claude",
        "github-copilot",
        "langchain"
      ],
      "policyRef": "config/mcp-connectors.example.json"
    }
  },
  "safeUsage": {
    "operatorActivationRequired": true,
    "operatorApprovalRequiredForWrites": true,
    "denyCustomerDataInPrompts": true,
    "redactTokensInLogs": true,
    "noExternalNetworkWithoutOperatorApproval": true
  },
  "runtimeEquivalence": {
    "sourceOfTruth": "dist/copilots/sonarqube_remediation/shared/spec.json",
    "runtimes": [
      "codex",
      "claude",
      "github-copilot",
      "langchain"
    ],
    "adapterFiles": {
      "codex": "dist/copilots/sonarqube_remediation/codex/AGENT.md",
      "claude": "dist/copilots/sonarqube_remediation/claude/AGENT.md",
      "github-copilot": "dist/copilots/sonarqube_remediation/github-copilot/copilot-agent.md",
      "langchain": "dist/copilots/sonarqube_remediation/langchain/agent.py"
    },
    "maxUnexplainedDrift": 0
  }
}
